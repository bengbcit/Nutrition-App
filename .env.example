# ============================================
# AI Provider (option: mock | groq | gemini | nvidia)
# ============================================
ANALYSIS_PROVIDER=mock

# Groq API Key (https://console.groq.com/)
GROQ_API_KEY=

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# NVIDIA API Key (https://build.nvidia.com/)
NVIDIA_API_KEY=

# ============================================
# Raspberry Pi CSI Camera Settings
# ============================================
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_JPEG_QUALITY=95
CAMERA_WARMUP_MS=1500

# ============================================
# (Future) Supabase Configuration
# ============================================
# Get these from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx
# IMPORTANT: service_role key is server-side only — never expose to the browser
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=